# Backend
DATABASE_PATH=/data/advisor.db

# ChromaDB (Docker Compose sets these automatically)
CHROMA_HOST=
CHROMA_PORT=8000

# Auth (set to false in production)
AUTH_DEV_MODE=true

# Azure AI Foundry (Phase 3 — optional, app works without)
AZURE_FOUNDRY_ENDPOINT=
AZURE_FOUNDRY_AGENT_NAME=greg
AZURE_FOUNDRY_AGENT_VERSION=1

# Frontend (build-time)
VITE_API_URL=http://localhost:8000
